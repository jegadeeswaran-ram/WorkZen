{
  "name": "workzen-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise ERP for Manpower Supply Companies",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=database",
    "db:migrate": "turbo run db:migrate --filter=database",
    "db:seed": "turbo run db:seed --filter=database",
    "db:studio": "turbo run db:studio --filter=database",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "graphql": "^16.14.2"
  }
}
