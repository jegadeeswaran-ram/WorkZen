# ========================================
# WorkZen ERP — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ========================================

# ----------------------------------------
# Application
# ----------------------------------------
NODE_ENV=development
APP_NAME=WorkZen
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ----------------------------------------
# Database
# ----------------------------------------
DATABASE_URL="postgresql://workzen:workzen_pass@localhost:5432/workzen_db?schema=public"
DATABASE_SHADOW_URL="postgresql://workzen:workzen_pass@localhost:5433/workzen_shadow?schema=public"

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ----------------------------------------
# JWT Authentication
# ----------------------------------------
JWT_SECRET=change_this_to_a_very_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------
# Two-Factor Authentication
# ----------------------------------------
TOTP_APP_NAME=WorkZen

# ----------------------------------------
# AWS S3 / MinIO Storage
# ----------------------------------------
STORAGE_PROVIDER=minio
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=workzen-docs
AWS_S3_ENDPOINT=http://localhost:9000

# ----------------------------------------
# Email (SMTP)
# ----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="WorkZen <noreply@workzen.com>"

# ----------------------------------------
# SMS - Twilio
# ----------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ----------------------------------------
# WhatsApp - WATI
# ----------------------------------------
WATI_API_URL=
WATI_API_TOKEN=

# ----------------------------------------
# Firebase Push Notifications
# ----------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ----------------------------------------
# AI Features - Claude API
# ----------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------
# Encryption
# ----------------------------------------
ENCRYPTION_KEY=32_char_hex_key_for_field_encryption

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ----------------------------------------
# Cors
# ----------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------------
# Super Admin (seed)
# ----------------------------------------
SUPER_ADMIN_EMAIL=admin@workzen.com
SUPER_ADMIN_PASSWORD=Admin@123456
