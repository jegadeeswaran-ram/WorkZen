# ========================================
# WorkZen ERP — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ========================================

# ----------------------------------------
# Application
# ----------------------------------------
NODE_ENV=production
APP_NAME=WorkZen
APP_URL=https://workzen.redonix.in
API_URL=https://workzen.redonix.in
PORT=3001

# ----------------------------------------
# Database (MySQL - Hostinger)
# Note: URL-encode @ as %40 in password
# ----------------------------------------
DATABASE_URL="mysql://u547357606_workzen:YOUR_DB_PASSWORD@localhost:3306/u547357606_workzen"

# ----------------------------------------
# Redis
# Install on server: apt-get install redis-server
# Or use Upstash free tier: https://upstash.com
# ----------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ----------------------------------------
# JWT Authentication
# ----------------------------------------
JWT_SECRET=change_this_to_a_very_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------
# Two-Factor Authentication
# ----------------------------------------
TOTP_APP_NAME=WorkZen

# ----------------------------------------
# File Storage (Cloudflare R2 or Backblaze B2)
# ----------------------------------------
STORAGE_PROVIDER=s3
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=workzen-docs
AWS_S3_ENDPOINT=https://your-endpoint-here

# ----------------------------------------
# Email (SMTP)
# ----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="WorkZen <noreply@workzen.redonix.in>"

# ----------------------------------------
# SMS - Twilio
# ----------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ----------------------------------------
# WhatsApp - WATI
# ----------------------------------------
WATI_API_URL=
WATI_API_TOKEN=

# ----------------------------------------
# Firebase Push Notifications
# ----------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ----------------------------------------
# AI Features - Claude API
# ----------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------
# Encryption
# ----------------------------------------
ENCRYPTION_KEY=32_char_hex_key_for_field_encryption

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ----------------------------------------
# CORS
# ----------------------------------------
CORS_ORIGINS=https://workzen.redonix.in

# ----------------------------------------
# Next.js Public / Internal
# ----------------------------------------
NEXT_PUBLIC_API_URL=https://workzen.redonix.in
# Internal URL used by the Next.js server to proxy /api/v1 to NestJS (server-side only)
API_INTERNAL_URL=http://localhost:3001

# ----------------------------------------
# Super Admin (seed)
# ----------------------------------------
SUPER_ADMIN_EMAIL=admin@workzen.redonix.in
SUPER_ADMIN_PASSWORD=Admin@123456
