// ============================================================
// MULTI-TENANT FOUNDATION
// ============================================================

model Tenant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  domain           String?          @unique
  logo             String?
  status           TenantStatus     @default(TRIAL)
  plan             SubscriptionPlan @default(FREE)
  planExpiresAt    DateTime?
  maxUsers         Int              @default(10)
  maxEmployees     Int              @default(100)
  settings         Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  organizations    Organization[]
  users            User[]
  auditLogs        AuditLog[]
  subscriptions    Subscription[]

  @@index([slug])
  @@map("tenants")
}

model Subscription {
  id          String           @id @default(cuid())
  tenantId    String
  plan        SubscriptionPlan
  startDate   DateTime
  endDate     DateTime?
  amount      Decimal          @db.Decimal(10, 2)
  currency    String           @default("INR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("subscriptions")
}

model Organization {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  displayName     String?
  gstin           String?
  pan             String?
  tan             String?
  cin             String?
  address         Json
  phone           String?
  email           String?
  website         String?
  logo            String?
  registrationNo  String?
  licenseNo       String?
  epfCode         String?
  esiCode         String?
  ptCode          String?
  settings        Json      @default("{}")
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  users           User[]

  @@index([tenantId])
  @@map("organizations")
}

// ============================================================
// USERS & RBAC
// ============================================================

model User {
  id             String     @id @default(cuid())
  tenantId       String
  organizationId String?
  email          String
  phone          String?
  passwordHash   String
  firstName      String
  lastName       String
  avatar         String?
  status         UserStatus @default(PENDING_VERIFICATION)
  twoFaEnabled   Boolean    @default(false)
  twoFaSecret    String?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  emailVerifiedAt DateTime?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  employee       Employee?
  notifications  Notification[]
  auditLogs      AuditLog[]
  approvals      Approval[]
  reportedComplaints   SiteComplaint[]   @relation("ComplaintReporter")
  assignedComplaints   SiteComplaint[]   @relation("ComplaintAssignee")
  activityLogs         SiteActivityLog[] @relation("ActivityLogSupervisor")
  supervisedSites      Site[]            @relation("SiteSupervisor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Role {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  displayName String
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime  @default(now())

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// MODULE 1: TENDER MANAGEMENT
// ============================================================

model Tender {
  id                String       @id @default(cuid())
  tenantId          String
  tenderNumber      String
  tenderName        String
  departmentId      String?
  tenderValue       Decimal      @db.Decimal(15, 2)
  estimatedValue    Decimal?     @db.Decimal(15, 2)
  bidDate           DateTime?
  awardDate         DateTime?
  startDate         DateTime?
  endDate           DateTime?
  contractType      ContractType @default(FIXED_TERM)
  status            TenderStatus @default(DRAFT)
  description       String?
  workLocations     Json         @default("[]")
  requiredEmployees Int          @default(0)
  emdAmount         Decimal?     @db.Decimal(15, 2)
  emdPaidDate       DateTime?
  emdRefundDate     DateTime?
  securityDeposit   Decimal?     @db.Decimal(15, 2)
  securityPaidDate  DateTime?
  bidReference      String?
  notes             String?
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  department        Client?      @relation(fields: [departmentId], references: [id])
  workOrders        WorkOrder[]
  tenderDocuments   TenderDocument[]
  deployments       Deployment[]
  invoices          Invoice[]
  quotations        Quotation[]
  renewals          TenderRenewal[]
  rateMasters       RateMaster[]
  billingSheets     BillingSheet[]
  costEntries       TenderCostEntry[]
  profitability     TenderProfitability[]

  @@unique([tenantId, tenderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([endDate])
  @@map("tenders")
}

model WorkOrder {
  id                 String    @id @default(cuid())
  tenantId           String
  tenderId           String
  workOrderNo        String
  title              String
  description        String?
  governmentRef      String?
  issuedDate         DateTime? @db.Date
  startDate          DateTime
  endDate            DateTime?
  value              Decimal   @db.Decimal(15, 2)
  requiredCount      Int       @default(0)
  sanctionedStrength Int       @default(0)
  location           Json?
  status             String    @default("ACTIVE")
  currentVersion     Int       @default(1)
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  tender             Tender               @relation(fields: [tenderId], references: [id])
  deployments        Deployment[]
  positions          WorkOrderPosition[]
  milestones         WorkOrderMilestone[]
  amendments         WorkOrderAmendment[]
  woInvoices         WorkOrderInvoice[]
  woPayments         WorkOrderPayment[]
  fulfillments       WorkOrderFulfillment[]

  @@unique([tenantId, workOrderNo])
  @@index([tenantId])
  @@index([tenderId])
  @@map("work_orders")
}

model TenderDocument {
  id           String    @id @default(cuid())
  tenantId     String
  tenderId     String
  documentId   String
  documentType String
  createdAt    DateTime  @default(now())

  tender       Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  document     Document  @relation(fields: [documentId], references: [id])

  @@index([tenderId])
  @@map("tender_documents")
}

model TenderRenewal {
  id          String    @id @default(cuid())
  tenantId    String
  tenderId    String
  renewalDate DateTime
  newEndDate  DateTime
  notes       String?
  createdBy   String?
  createdAt   DateTime  @default(now())

  tender      Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@map("tender_renewals")
}

// ============================================================
// MODULE 2: CLIENT MANAGEMENT
// ============================================================

model Client {
  id           String     @id @default(cuid())
  tenantId     String
  clientCode   String
  name         String
  shortName    String?
  clientType   ClientType @default(GOVERNMENT_DEPARTMENT)
  gstin        String?
  pan          String?
  tan          String?
  address      Json
  billingAddress Json?
  paymentTerms Int        @default(30)
  creditLimit  Decimal?   @db.Decimal(15, 2)
  website      String?
  notes        String?
  isActive     Boolean    @default(true)
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  contacts             ClientContact[]
  tenders              Tender[]
  invoices             Invoice[]
  quotations           Quotation[]
  rateMasters          RateMaster[]
  billingSheets        BillingSheet[]
  customerLedger       CustomerLedger[]
  creditLimitUsed      Decimal?  @db.Decimal(15, 2) @default(0)
  remindersSent        Int       @default(0)
  lastReminderAt       DateTime?

  @@unique([tenantId, clientCode])
  @@index([tenantId])
  @@map("clients")
}

model ClientContact {
  id         String   @id @default(cuid())
  tenantId   String
  clientId   String
  name       String
  designation String?
  email      String?
  phone      String?
  mobile     String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

// ============================================================
// MODULE 3: EMPLOYEE MANAGEMENT
// ============================================================

model Employee {
  id                  String         @id @default(cuid())
  tenantId            String
  employeeCode        String
  userId              String?        @unique
  firstName           String
  lastName            String
  fatherName          String?
  motherName          String?
  dateOfBirth         DateTime?
  gender              Gender?
  maritalStatus       MaritalStatus?
  bloodGroup          BloodGroup?
  nationality         String?        @default("Indian")
  religion            String?
  category            String?
  photo               String?
  digitalSignature    String?

  // Contact
  personalEmail       String?
  personalPhone       String
  alternatePhone      String?
  permanentAddress    Json?
  currentAddress      Json?

  // Government IDs
  aadhaarNumber       String?
  panNumber           String?
  voterIdNumber       String?
  drivingLicense      String?
  passportNumber      String?
  passportExpiry      DateTime?

  // PF & ESI
  pfNumber            String?
  esiNumber           String?
  uanNumber           String?

  // Employment Details
  joiningDate         DateTime?
  confirmationDate    DateTime?
  designationId       String?
  departmentId        String?
  branchId            String?
  reportingManagerId  String?
  employmentType      String         @default("CONTRACT")
  status              EmployeeStatus @default(ACTIVE)
  lifecycleStatus     EmployeeLifecycleStatus @default(JOINED)
  relievingDate       DateTime?
  relievingReason     String?
  noticePeriodDays    Int?           @default(30)

  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyRelation     String?

  createdBy           String?
  updatedBy           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  user                User?          @relation(fields: [userId], references: [id])
  designation         Designation?   @relation(fields: [designationId], references: [id])
  department          Department?    @relation(fields: [departmentId], references: [id])
  branch              Branch?        @relation(fields: [branchId], references: [id])
  bankDetails         BankDetail[]
  documents           EmployeeDocument[]
  deployments         Deployment[]
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  payslips            Payslip[]
  complianceItems     EmployeeCompliance[]
  assetAssignments    AssetAssignment[]
  employmentHistory   EmploymentHistory[]
  salaryStructures    SalaryStructure[]
  billingSheetLines   BillingSheetLine[]
  timesheets          Timesheet[]
  regularizations     AttendanceRegularization[]
  biometricLogs       BiometricPunchLog[]
  transferRequests    TransferRequest[]
  promotionRecords    PromotionRecord[]
  separationRecord    SeparationRecord?
  awards              EmployeeAward[]
  warnings            WarningRecord[]
  trips               EmployeeTrip[]
  goals               EmployeeGoal[]
  performanceReviews  PerformanceReview[]
  trainings           EmployeeTraining[]
  trainingCerts       TrainingCertificate[]
  woFulfillments      WorkOrderFulfillment[]
  hostedVisitors      VisitorLog[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("employees")
}

model Designation {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  level       Int?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees         Employee[]
  rateMasters       RateMaster[]
  billingSheetLines BillingSheetLine[]

  @@unique([tenantId, name])
  @@map("designations")
}

model Department {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  parentId    String?
  headUserId  String?
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]

  @@unique([tenantId, name])
  @@map("departments")
}

model BankDetail {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  accountName     String
  accountNumber   String
  ifscCode        String
  bankName        String
  branchName      String?
  accountType     String   @default("SAVINGS")
  isPrimary       Boolean  @default(false)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("bank_details")
}

model EmployeeDocument {
  id           String       @id @default(cuid())
  tenantId     String
  employeeId   String
  documentId   String
  documentType DocumentType
  expiryDate   DateTime?
  isVerified   Boolean      @default(false)
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  document     Document     @relation(fields: [documentId], references: [id])

  @@index([employeeId])
  @@map("employee_documents")
}

model EmploymentHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  companyName   String
  designation   String?
  startDate     DateTime
  endDate       DateTime?
  salary        Decimal? @db.Decimal(10, 2)
  reasonLeaving String?
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employment_history")
}

// ============================================================
// MODULE 4: RECRUITMENT
// ============================================================

model JobRequisition {
  id               String            @id @default(cuid())
  tenantId         String
  requisitionNo    String
  title            String
  tenderId         String?
  departmentId     String?
  designationId    String?
  vacancies        Int               @default(1)
  status           RecruitmentStatus @default(OPEN)
  urgency          String            @default("NORMAL")
  skills           Json              @default("[]")
  qualification    String?
  experience       String?
  salaryRange      Json?
  location         String?
  targetDate       DateTime?
  description      String?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  candidates       Candidate[]

  @@unique([tenantId, requisitionNo])
  @@index([tenantId])
  @@map("job_requisitions")
}

model Candidate {
  id                String          @id @default(cuid())
  tenantId          String
  requisitionId     String
  firstName         String
  lastName          String
  email             String?
  phone             String
  dateOfBirth       DateTime?
  gender            Gender?
  currentAddress    String?
  qualification     String?
  experience        String?
  currentSalary     Decimal?        @db.Decimal(10, 2)
