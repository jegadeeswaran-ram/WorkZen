model Document {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  fileName     String
  fileType     String
  fileSize     Int
  filePath     String
  s3Key        String?
  documentType DocumentType @default(OTHER)
  description  String?
  tags         Json         @default("[]")
  isPublic     Boolean      @default(false)
  expiryDate   DateTime?
  ocrText      String?
  uploadedBy   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  versions     DocumentVersion[]
  employeeDocs EmployeeDocument[]
  tenderDocs   TenderDocument[]

  @@index([tenantId])
  @@index([tenantId, documentType])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  version     Int
  fileName    String
  filePath    String
  s3Key       String?
  fileSize    Int
  notes       String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

// ============================================================
// MODULE 13: WORKFLOW ENGINE
// ============================================================

model WorkflowDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  module      String
  description String?
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       WorkflowStep[]
  instances   WorkflowInstance[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id             String    @id @default(cuid())
  workflowId     String
  stepOrder      Int
  name           String
  approverRole   String?
  approverUserId String?
  isMandatory    Boolean   @default(true)
  timeoutHours   Int?

  workflow       WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id           String         @id @default(cuid())
  tenantId     String
  workflowId   String
  entityType   String
  entityId     String
  status       WorkflowStatus @default(PENDING)
  currentStep  Int            @default(0)
  initiatedBy  String
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  workflow     WorkflowDefinition @relation(fields: [workflowId], references: [id])
  approvals    Approval[]

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("workflow_instances")
}

model Approval {
  id                 String         @id @default(cuid())
  tenantId           String
  workflowInstanceId String
  stepOrder          Int
  approverId         String
  action             ApprovalAction?
  comments           String?
  actionedAt         DateTime?
  createdAt          DateTime       @default(now())

  instance           WorkflowInstance @relation(fields: [workflowInstanceId], references: [id])
  approver           User             @relation(fields: [approverId], references: [id])

  @@index([workflowInstanceId])
  @@index([approverId])
  @@map("approvals")
}

// ============================================================
// MODULE 14: REPORTS & ANALYTICS
