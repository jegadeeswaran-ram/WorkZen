  completedAt      DateTime?
  errorMessage     String?

  report           ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([tenantId])
  @@index([reportId])
  @@map("report_executions")
}

// ============================================================
// NOTIFICATIONS
